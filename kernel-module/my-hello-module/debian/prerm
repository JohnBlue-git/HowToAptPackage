#!/bin/sh
# prerm script for my-hello-module
#
# Unloads the module and removes it from DKMS before package removal.

set -e

PACKAGE_NAME=my-hello-module
PACKAGE_VERSION=1.0.0

case "$1" in
    remove|upgrade|deconfigure)
        # Unload the module
        modprobe -r myhello 2>/dev/null || true

        # Remove from DKMS
        if command -v dkms >/dev/null 2>&1; then
            dkms remove -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION" --all 2>/dev/null || true
        fi
        ;;
    failed-upgrade)
        ;;
    *)
        echo "prerm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0