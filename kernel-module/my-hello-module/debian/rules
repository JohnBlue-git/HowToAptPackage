#!/usr/bin/make -f
# debian/rules for my-hello-module
#
# Uses DKMS to register and build the kernel module.
# The module source is installed to /usr/src/<package>-<version>
# so DKMS can rebuild it automatically for new kernels.

export DEB_BUILD_MAINT_OPTIONS := hardening=+all

PACKAGE_NAME := my-hello-module
PACKAGE_VERSION := 1.0.0
DKMS_SOURCE_DIR := /usr/src/$(PACKAGE_NAME)-$(PACKAGE_VERSION)

%:
	dh $@

override_dh_auto_build:
	# No build during package build - DKMS builds on the target machine
	# dh_auto_build

override_dh_auto_clean:
	# Simple clean - don't invoke kernel build system clean
	rm -rf build
	rm -f debian/*.debhelper

override_dh_auto_install:
	# Create the DKMS source tree
	mkdir -p debian/$(PACKAGE_NAME)$(DKMS_SOURCE_DIR)/src

	# Copy only source files (no build artifacts) to DKMS source directory
	cp src/hello.c debian/$(PACKAGE_NAME)$(DKMS_SOURCE_DIR)/src/
	cp Makefile debian/$(PACKAGE_NAME)$(DKMS_SOURCE_DIR)/
	cp dkms.conf debian/$(PACKAGE_NAME)$(DKMS_SOURCE_DIR)/
