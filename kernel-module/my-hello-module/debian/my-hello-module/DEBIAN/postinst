#!/bin/sh
# postinst script for my-hello-module
#
# Registers the module with DKMS and loads it.

set -e

PACKAGE_NAME=my-hello-module
PACKAGE_VERSION=1.0.0

case "$1" in
    configure)
        # Register with DKMS
        if command -v dkms >/dev/null 2>&1; then
            dkms add -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION" 2>/dev/null || true
            dkms build -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION" 2>/dev/null || true
            dkms install -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION" 2>/dev/null || true
        fi

        # Load the module
        modprobe myhello 2>/dev/null || true
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0